---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <!-- Navigation -->
    <nav class="fixed w-full z-50 glass-nav border-b border-white/30">
        <div
            class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between"
        >
            <!-- Logo -->
            <a
                href="#"
                class="text-2xl font-extrabold tracking-tighter text-slate-900 font-heading"
            >
                ENG<span class="text-rose-500">GROHO</span>
            </a>

            <!-- Menu Navbar Tetap Ada -->
            <div class="hidden lg:flex space-x-10 font-semibold text-slate-600">
                <a href="#about" class="nav-link hover:text-rose-500">Tentang</a
                >
                <a href="#approach" class="nav-link hover:text-rose-500"
                    >Metode</a
                >
                <a href="#testimonials" class="nav-link hover:text-rose-500"
                    >Testimoni</a
                >
                <a href="#mentor" class="nav-link hover:text-rose-500">Mentor</a
                >
            </div>

            <!-- Call to Action -->
            <a
                href="https://wa.me/6287736696629"
                class="btn-primary text-white px-8 py-3.5 rounded-2xl font-bold text-sm shadow-xl"
            >
                Kelas Gratis
            </a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section
        id="hero"
        class="relative min-h-[90vh] flex items-center pt-20 px-6 overflow-hidden"
    >
        <div class="blob-bg -top-24 -right-24"></div>
        <div class="blob-bg -bottom-48 -left-24 opacity-60"></div>

        <div
            class="max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-20 items-center"
        >
            <div class="relative z-10" data-aos="fade-right">
                <div
                    class="inline-flex items-center space-x-3 mb-8 px-4 py-2 bg-slate-50 rounded-2xl border border-slate-100"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"
                        ></span>
                    </span>
                    <span
                        class="text-slate-700 text-[11px] font-bold uppercase tracking-widest"
                        >Global Career Accelerator</span
                    >
                </div>

                <h1
                    class="text-4xl sm:text-5xl md:text-7xl font-extrabold leading-[1.1] mb-8 text-slate-900 tracking-tight"
                >
                    Break Boundaries with <span class="gradient-text italic"
                        >Fluent</span
                    > English
                </h1>

                <p
                    class="text-lg md:text-xl text-slate-500 mb-12 leading-relaxed max-w-xl font-light"
                >
                    Transformasikan cara Anda berkomunikasi. Kami tidak hanya
                    mengajar bahasa, kami membantu Anda membangun <span
                        class="text-slate-900 font-semibold"
                        >karakter profesional</span
                    > di panggung internasional.
                </p>

                <div class="flex flex-col sm:flex-row items-center gap-8">
                    <a
                        href="https://wa.me/6287736696629"
                        class="btn-primary text-white px-12 py-5 rounded-3xl font-bold text-center text-lg w-full sm:w-auto"
                    >
                        Mulai Perjalanan Anda
                    </a>

                    <div class="flex items-center space-x-4">
                        <div class="flex -space-x-3">
                            <img
                                src="https://i.pravatar.cc/150?u=a1"
                                class="w-11 h-11 rounded-full border-2 border-white shadow-md"
                                alt="User"
                            />
                            <img
                                src="https://i.pravatar.cc/150?u=a2"
                                class="w-11 h-11 rounded-full border-2 border-white shadow-md"
                                alt="User"
                            />
                            <img
                                src="https://i.pravatar.cc/150?u=a3"
                                class="w-11 h-11 rounded-full border-2 border-white shadow-md"
                                alt="User"
                            />
                            <div
                                class="w-11 h-11 rounded-full border-2 border-white bg-rose-500 text-white flex items-center justify-center text-[10px] font-black shadow-md"
                            >
                                20+
                            </div>
                        </div>
                        <p
                            class="text-xs font-medium text-slate-500 leading-tight"
                        >
                            Dipercaya oleh para<br /><span
                                class="text-slate-900 font-bold"
                                >Executive Leader</span
                            >
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="relative"
                data-aos="zoom-out-up"
                data-aos-duration="1200"
            >
                <div
                    class="absolute -top-10 -right-5 w-32 h-32 bg-yellow-400/20 rounded-full blur-3xl"
                >
                </div>

                <div
                    class="absolute -left-12 top-20 glass-card p-6 flex items-center space-x-4 floating z-30 border-rose-100/50"
                >
                    <div
                        class="w-12 h-12 bg-rose-500 text-white rounded-2xl flex items-center justify-center text-xl shadow-lg"
                    >
                        <i class="fas fa-rocket"></i>
                    </div>
                    <div>
                        <p
                            class="text-[10px] uppercase font-bold text-slate-400"
                        >
                            Career Growth
                        </p>
                        <p class="text-sm font-extrabold text-slate-800">
                            Accelerated
                        </p>
                    </div>
                </div>

                <div class="creative-frame relative group">
                    <img
                        src="/hero.png"
                        alt="Professional Leadership"
                        class="w-full h-[600px] object-cover transition-transform duration-1000 group-hover:scale-105"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-rose-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Methodology Section -->
    <section id="approach" class="py-32 px-6 bg-white overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div
                class="flex flex-col items-center text-center mb-24"
                data-aos="fade-up"
            >
                <span
                    class="text-rose-500 font-bold text-xs uppercase tracking-[0.3em] mb-6 px-4 py-1.5 rounded-full bg-rose-50"
                    >Our Creative Approach</span
                >
                <h2
                    class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight"
                >
                    Metode Belajar Tanpa Batas
                </h2>
            </div>

            <div class="grid md:grid-cols-3 gap-10">
                <div
                    class="glass-card p-12 hover:border-rose-100"
                    data-aos="fade-up"
                    data-aos-delay="100"
                >
                    <div
                        class="w-14 h-14 bg-rose-50 text-rose-500 rounded-2xl flex items-center justify-center mb-8 text-2xl"
                    >
                        <i class="fas fa-fingerprint"></i>
                    </div>
                    <h3 class="text-2xl font-bold mb-5 tracking-tight">
                        Ultra Personalized
                    </h3>
                    <p class="text-slate-500 leading-relaxed font-light">
                        Kurikulum yang berputar di sekitar dunia kerja Anda.
                        Anda belajar apa yang Anda butuhkan besok di kantor.
                    </p>
                </div>

                <div
                    class="glass-card p-12 bg-slate-900 border-none group hover:scale-[1.02]"
                    data-aos="fade-up"
                    data-aos-delay="200"
                >
                    <div
                        class="w-14 h-14 bg-rose-500 text-white rounded-2xl flex items-center justify-center mb-8 text-2xl group-hover:rotate-12 transition-transform"
                    >
                        <i class="fas fa-brain"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold mb-5 text-white tracking-tight"
                    >
                        Cognitive Context
                    </h3>
                    <p class="text-slate-400 leading-relaxed font-light">
                        Kami melatih otak Anda untuk berpikir langsung dalam
                        bahasa Inggris, bukan sekadar menerjemahkan kata.
                    </p>
                </div>

                <div
                    class="glass-card p-12 hover:border-rose-100"
                    data-aos="fade-up"
                    data-aos-delay="300"
                >
                    <div
                        class="w-14 h-14 bg-indigo-50 text-indigo-500 rounded-2xl flex items-center justify-center mb-8 text-2xl"
                    >
                        <i class="fas fa-infinity"></i>
                    </div>
                    <h3 class="text-2xl font-bold mb-5 tracking-tight">
                        Unlimited Support
                    </h3>
                    <p class="text-slate-500 leading-relaxed font-light">
                        Akses tanya jawab di luar sesi kelas. Kami adalah
                        partner komunikasi Anda setiap saat.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats / Impact Section -->
    <section class="py-24 px-6 bg-[#fafbff] overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div
                class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12"
                data-aos="fade-up"
            >
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-rose-500 mb-3 font-heading"
                    >
                        200+
                    </p>
                    <p
                        class="text-sm text-slate-500 font-medium uppercase tracking-wider"
                    >
                        Alumni Aktif
                    </p>
                </div>
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-3 font-heading"
                    >
                        5+
                    </p>
                    <p
                        class="text-sm text-slate-500 font-medium uppercase tracking-wider"
                    >
                        Tahun Pengalaman
                    </p>
                </div>
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-rose-500 mb-3 font-heading"
                    >
                        98%
                    </p>
                    <p
                        class="text-sm text-slate-500 font-medium uppercase tracking-wider"
                    >
                        Tingkat Kepuasan
                    </p>
                </div>
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-3 font-heading"
                    >
                        15+
                    </p>
                    <p
                        class="text-sm text-slate-500 font-medium uppercase tracking-wider"
                    >
                        Industri Dilayani
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="py-32 px-6 bg-white overflow-hidden" id="metode">
        <div class="max-w-5xl mx-auto">
            <div
                class="flex flex-col items-center text-center mb-24"
                data-aos="fade-up"
            >
                <span
                    class="text-rose-500 font-bold text-xs uppercase tracking-[0.3em] mb-6 px-4 py-1.5 rounded-full bg-rose-50"
                    >How It Works</span
                >
                <h2
                    class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight"
                >
                    Alur Belajar di Enggroho
                </h2>
                <p class="text-slate-500 mt-6 text-lg max-w-2xl font-light">
                    Dari nol hingga mahir, kami mendampingi setiap langkah
                    perjalanan Anda menuju komunikasi profesional.
                </p>
            </div>

            <div class="relative">
                <!-- Vertical Timeline Line -->
                <div
                    class="absolute left-8 md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-[3px] bg-slate-100 z-0"
                >
                </div>
                <div
                    class="absolute left-8 md:left-1/2 md:-translate-x-1/2 top-0 w-[3px] bg-gradient-to-b from-rose-500 to-rose-300 z-[1] timeline-progress"
                    style="height: 0%"
                >
                </div>

                <!-- Step 1 -->
                <div
                    class="step-item relative flex items-start mb-20 md:mb-28"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-white border-[3px] border-slate-200 flex items-center justify-center text-2xl font-extrabold text-slate-300 font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">1</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-0 md:w-[42%] md:pr-16">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-rose-400 mb-2 block"
                            >Langkah Pertama</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-slate-900"
                        >
                            Konsultasi Gratis
                        </h3>
                        <p class="text-slate-500 font-light leading-relaxed">
                            Kami mendengarkan kebutuhan, tantangan, dan tujuan
                            karier Anda secara menyeluruh. Sesi ini gratis tanpa
                            komitmen apapun.
                        </p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div
                    class="step-item relative flex items-start justify-end mb-20 md:mb-28"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-white border-[3px] border-slate-200 flex items-center justify-center text-2xl font-extrabold text-slate-300 font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">2</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-0 md:w-[42%] md:pl-16 md:text-left">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-rose-400 mb-2 block"
                            >Langkah Kedua</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-slate-900"
                        >
                            Kurikulum Personal
                        </h3>
                        <p class="text-slate-500 font-light leading-relaxed">
                            Materi disusun khusus berdasarkan industri dan
                            kebutuhan profesional Anda. Tidak ada kurikulum
                            template — semuanya tailor-made.
                        </p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div
                    class="step-item relative flex items-start mb-20 md:mb-28"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-white border-[3px] border-slate-200 flex items-center justify-center text-2xl font-extrabold text-slate-300 font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">3</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-0 md:w-[42%] md:pr-16">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-rose-400 mb-2 block"
                            >Langkah Ketiga</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-slate-900"
                        >
                            Sesi Intensif 1-on-1
                        </h3>
                        <p class="text-slate-500 font-light leading-relaxed">
                            Belajar langsung dengan mentor melalui sesi privat
                            yang fokus dan interaktif. Real practice, real
                            scenario, real progress.
                        </p>
                    </div>
                </div>

                <!-- Step 4 -->
                <div
                    class="step-item relative flex items-start justify-end"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-white border-[3px] border-slate-200 flex items-center justify-center text-2xl font-extrabold text-slate-300 font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">4</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-0 md:w-[42%] md:pl-16 md:text-left">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-rose-400 mb-2 block"
                            >Langkah Terakhir</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-slate-900"
                        >
                            Evaluasi & Follow Up
                        </h3>
                        <p class="text-slate-500 font-light leading-relaxed">
                            Perkembangan dipantau, dievaluasi, dan disesuaikan
                            agar progres Anda makin optimal dari waktu ke waktu.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mentor Profile -->
    <section id="mentor" class="py-32 px-6 bg-[#fafbff] overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-20 items-center">
                <div data-aos="fade-right">
                    <span
                        class="text-rose-500 font-bold text-xs uppercase tracking-[0.3em] mb-6 inline-block px-4 py-1.5 rounded-full bg-rose-50"
                        >Kenapa Enggroho?</span
                    >
                    <h2
                        class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mt-4 mb-8"
                    >
                        Bukan Sekadar Kursus Bahasa Inggris <span
                            class="gradient-text italic">Biasa</span
                        >
                    </h2>
                    <p
                        class="text-lg text-slate-500 mb-12 leading-relaxed font-light"
                    >
                        Enggroho hadir dengan pendekatan yang berbeda. Kami
                        tidak hanya mengajarkan grammar dan vocabulary, tapi
                        membentuk cara berpikir dan berkomunikasi Anda secara
                        menyeluruh di dunia profesional.
                    </p>

                    <div class="space-y-8">
                        <div class="flex items-start space-x-5">
                            <div
                                class="w-12 h-12 bg-rose-500 rounded-2xl flex items-center justify-center text-white text-lg shrink-0 shadow-lg shadow-rose-200"
                            >
                                <i class="fas fa-bullseye"></i>
                            </div>
                            <div>
                                <h4
                                    class="font-bold text-slate-900 text-lg mb-2"
                                >
                                    Fokus ke Dunia Kerja Nyata
                                </h4>
                                <p
                                    class="text-slate-500 font-light leading-relaxed"
                                >
                                    Materi belajar dirancang langsung dari
                                    skenario pekerjaan: presentasi, negosiasi,
                                    email bisnis, hingga interview kerja.
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start space-x-5">
                            <div
                                class="w-12 h-12 bg-slate-900 rounded-2xl flex items-center justify-center text-white text-lg shrink-0 shadow-lg shadow-slate-300"
                            >
                                <i class="fas fa-users"></i>
                            </div>
                            <div>
                                <h4
                                    class="font-bold text-slate-900 text-lg mb-2"
                                >
                                    Mentoring, Bukan Sekadar Mengajar
                                </h4>
                                <p
                                    class="text-slate-500 font-light leading-relaxed"
                                >
                                    Anda tidak belajar sendirian. Kami menjadi
                                    partner komunikasi Anda bahkan di luar jam
                                    kelas.
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start space-x-5">
                            <div
                                class="w-12 h-12 bg-indigo-500 rounded-2xl flex items-center justify-center text-white text-lg shrink-0 shadow-lg shadow-indigo-200"
                            >
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div>
                                <h4
                                    class="font-bold text-slate-900 text-lg mb-2"
                                >
                                    Progress Terukur & Transparan
                                </h4>
                                <p
                                    class="text-slate-500 font-light leading-relaxed"
                                >
                                    Setiap sesi dinilai dan dievaluasi. Anda
                                    bisa melihat sendiri seberapa jauh kemajuan
                                    Anda dari waktu ke waktu.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="relative" data-aos="fade-left">
                    <div
                        class="absolute -top-10 -right-10 w-72 h-72 bg-rose-100/50 rounded-full blur-3xl -z-10"
                    >
                    </div>
                    <div class="grid grid-cols-2 gap-6">
                        <div
                            class="glass-card p-8 text-center hover:border-rose-100"
                            data-aos="zoom-in"
                            data-aos-delay="100"
                        >
                            <div
                                class="w-14 h-14 bg-rose-50 text-rose-500 rounded-2xl flex items-center justify-center mb-5 text-2xl mx-auto"
                            >
                                <i class="fas fa-laptop"></i>
                            </div>
                            <h4 class="font-bold text-slate-900 mb-2">
                                Online & Offline
                            </h4>
                            <p class="text-xs text-slate-500 font-light">
                                Fleksibel sesuai jadwal Anda
                            </p>
                        </div>
                        <div
                            class="glass-card p-8 text-center hover:border-rose-100"
                            data-aos="zoom-in"
                            data-aos-delay="200"
                        >
                            <div
                                class="w-14 h-14 bg-indigo-50 text-indigo-500 rounded-2xl flex items-center justify-center mb-5 text-2xl mx-auto"
                            >
                                <i class="fas fa-clock"></i>
                            </div>
                            <h4 class="font-bold text-slate-900 mb-2">
                                Jadwal Fleksibel
                            </h4>
                            <p class="text-xs text-slate-500 font-light">
                                Pagi, siang, malam — pilih sendiri
                            </p>
                        </div>
                        <div
                            class="glass-card p-8 text-center hover:border-rose-100"
                            data-aos="zoom-in"
                            data-aos-delay="300"
                        >
                            <div
                                class="w-14 h-14 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center mb-5 text-2xl mx-auto"
                            >
                                <i class="fas fa-headset"></i>
                            </div>
                            <h4 class="font-bold text-slate-900 mb-2">
                                Support 24/7
                            </h4>
                            <p class="text-xs text-slate-500 font-light">
                                Tanya jawab kapan saja via WhatsApp
                            </p>
                        </div>
                        <div
                            class="glass-card p-8 text-center hover:border-rose-100"
                            data-aos="zoom-in"
                            data-aos-delay="400"
                        >
                            <div
                                class="w-14 h-14 bg-emerald-50 text-emerald-500 rounded-2xl flex items-center justify-center mb-5 text-2xl mx-auto"
                            >
                                <i class="fas fa-certificate"></i>
                            </div>
                            <h4 class="font-bold text-slate-900 mb-2">
                                Sertifikat
                            </h4>
                            <p class="text-xs text-slate-500 font-light">
                                Bukti kompetensi untuk karier Anda
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <script is:inline define:vars={{ translations }}>
        function updateLanguage(lang) {
            const nextLang = lang === "id" ? "en" : "id";
            const label = lang === "id" ? "EN" : "ID";

            const t = translations[lang];
            if (!t) return;

            document.querySelectorAll("[data-t]").forEach((el) => {
                const key = el.getAttribute("data-t");
                if (t[key]) {
                    el.innerHTML = t[key];
                }
            });

            // Update toggle label
            const btnDesktop = document.getElementById("lang-toggle-desktop");
            const btnMobile = document.getElementById("lang-toggle-mobile");
            if (btnDesktop) btnDesktop.innerText = label;
            if (btnMobile) btnMobile.innerText = label;

            localStorage.setItem("language", lang);
            document.documentElement.lang = lang;
        }

        // Initialize language
        document.addEventListener("DOMContentLoaded", () => {
            let currentLang = localStorage.getItem("language") || "id";
            updateLanguage(currentLang);

            const toggles = [
                document.getElementById("lang-toggle-desktop"),
                document.getElementById("lang-toggle-mobile"),
            ];

            toggles.forEach((btn) => {
                if (btn)
                    btn.addEventListener("click", () => {
                        currentLang = currentLang === "id" ? "en" : "id";
                        updateLanguage(currentLang);
                    });
            });
        });

        // Testimonial Marquee & Modal Logic
        const marqueeContainer = document.querySelector('.marquee-container');
        const marqueeContent = document.querySelector('.marquee-content');
        const modal = document.getElementById('testi-modal');
        const modalOverlay = document.getElementById('modal-overlay');
        const closeModal = document.getElementById('close-modal');
        
        let isPaused = false;
        let speed = 0.5; // Pixels per frame
        let scrollPos = 0;
        let isDragging = false;
        let startX;
        let scrollLeft;

        function animate() {
            if (!isPaused && !isDragging) {
                scrollPos += speed;
                const limit = marqueeContent.scrollWidth / 2;
                
                if (scrollPos >= limit) {
                    scrollPos = 0;
                }
                
                marqueeContainer.scrollLeft = scrollPos;
            }
            requestAnimationFrame(animate);
        }

        // Mouse/Touch Events for Dragging
        marqueeContainer.addEventListener('mousedown', (e) => {
            isDragging = true;
            startX = e.pageX - marqueeContainer.offsetLeft;
            scrollLeft = marqueeContainer.scrollLeft;
            marqueeContainer.style.cursor = 'grabbing';
        });

        marqueeContainer.addEventListener('mouseleave', () => {
            isDragging = false;
            isPaused = false;
            marqueeContainer.style.cursor = 'grab';
        });

        marqueeContainer.addEventListener('mouseup', () => {
            isDragging = false;
            isPaused = false;
            marqueeContainer.style.cursor = 'grab';
            scrollPos = marqueeContainer.scrollLeft;
        });

        marqueeContainer.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            e.preventDefault();
            const x = e.pageX - marqueeContainer.offsetLeft;
            const walk = (x - startX) * 1.5;
            marqueeContainer.scrollLeft = scrollLeft - walk;
            scrollPos = marqueeContainer.scrollLeft;
        });

        // Touch Events
        marqueeContainer.addEventListener('touchstart', (e) => {
            isPaused = true;
            isDragging = true;
            startX = e.touches[0].pageX - marqueeContainer.offsetLeft;
            scrollLeft = marqueeContainer.scrollLeft;
        });

        marqueeContainer.addEventListener('touchend', () => {
            isDragging = false;
            isPaused = false;
            scrollPos = marqueeContainer.scrollLeft;
        });

        marqueeContainer.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            const x = e.touches[0].pageX - marqueeContainer.offsetLeft;
            const walk = (x - startX) * 1.5;
            marqueeContainer.scrollLeft = scrollLeft - walk;
            scrollPos = marqueeContainer.scrollLeft;
        });

        // Pause on Hover
        marqueeContainer.addEventListener('mouseenter', () => isPaused = true);
        marqueeContainer.addEventListener('mouseleave', () => isPaused = false);

        // Modal Logic
        document.querySelectorAll('.testimonial-card').forEach(card => {
            card.addEventListener('click', (e) => {
                // If it was a drag, don't open modal
                const dragDistance = startX ? Math.abs(startX - (e.pageX || e.touches?.[0]?.pageX || 0 - marqueeContainer.offsetLeft)) : 0;
                if (dragDistance > 10) return;

                const name = card.getAttribute('data-name');
                const role = card.getAttribute('data-role');
                const text = card.getAttribute('data-text');
                const image = card.getAttribute('data-image');

                document.getElementById('modal-name').innerText = name;
                document.getElementById('modal-role').innerText = role;
                document.getElementById('modal-text').innerText = `"${text}"`;
                document.getElementById('modal-image').src = image;

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            });
        });

        const closeFunc = () => {
            modal.classList.add('hidden');
            document.body.style.overflow = '';
        };

        closeModal.addEventListener('click', closeFunc);
        modalOverlay.addEventListener('click', closeFunc);

        // Start Animation
        requestAnimationFrame(animate);
    </script>

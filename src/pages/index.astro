---
import Layout from "../layouts/Layout.astro";
import { translations, testimonials } from "../utils/translations";
---

<Layout>
    <!-- Navigation -->
    <nav class="fixed w-full z-50 glass-nav border-b border-accent/30">
        <div
            class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between"
        >
            <!-- Logo -->
            <a
                href="#"
                class="flex items-center"
            >
                <svg class="h-12 md:h-14 w-auto" viewBox="0 0 600 180" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g transform="translate(60, 20)">
                        <text x="0" y="80" fill="#222222" style="font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 85px; letter-spacing: -2.5px;">Enggr</text>
                        <g transform="translate(232, 42)">
                            <rect width="65" height="38" rx="1" fill="none" stroke="#222222" stroke-width="2.5"/>
                            <clipPath id="splitClip">
                                <rect width="65" height="38" rx="1"/>
                            </clipPath>
                            <g clip-path="url(#splitClip)">
                                <path d="M0 0 L65 0 L0 38 Z" fill="#222222" fill-opacity="0.1"/>
                                <line x1="0" y1="5" x2="55" y2="5" stroke="#222222" stroke-width="2"/>
                                <line x1="0" y1="10" x2="48" y2="10" stroke="#222222" stroke-width="2"/>
                                <line x1="0" y1="15" x2="40" y2="15" stroke="#222222" stroke-width="2"/>
                                <line x1="0" y1="20" x2="32" y2="20" stroke="#222222" stroke-width="2"/>
                                <line x1="0" y1="25" x2="23" y2="25" stroke="#222222" stroke-width="2"/>
                                <rect x="0" y="0" width="18" height="14" fill="#222222"/>
                                <line x1="0" y1="38" x2="65" y2="0" stroke="#222222" stroke-width="2.5"/>
                                <g transform="translate(25, 12)">
                                     <line x1="0" y1="26" x2="40" y2="0" stroke="#222222" stroke-width="1"/>
                                     <line x1="5" y1="0" x2="40" y2="26" stroke="#222222" stroke-width="1"/>
                                     <line x1="22" y1="4" x2="22" y2="26" stroke="#222222" stroke-width="2.5"/>
                                     <line x1="4" y1="13" x2="40" y2="13" stroke="#222222" stroke-width="2.5"/>
                                </g>
                            </g>
                        </g>
                        <text x="305" y="80" fill="#222222" style="font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 85px; letter-spacing: -2.5px;">ho</text>
                        <text x="195" y="130" text-anchor="middle" fill="#222222" style="font-family: 'Outfit', sans-serif; font-weight: 600; font-size: 21px; letter-spacing: 2.2px;">YOUR ONE-STOP ENGLISH SOLUTIONS</text>
                    </g>
                </svg>
            </a>

            <!-- Menu Navbar Tetap Ada -->
            <div class="hidden lg:flex space-x-10 font-semibold text-secondary">
                <a
                    href="#about"
                    class="nav-link hover:text-primary"
                    data-t="nav_about">Tentang</a
                >
                <a
                    href="#approach"
                    class="nav-link hover:text-primary"
                    data-t="nav_method">Metode</a
                >
                <a
                    href="#testimonials"
                    class="nav-link hover:text-primary"
                    data-t="nav_testi">Testimoni</a
                >
                <a
                    href="#mentor"
                    class="nav-link hover:text-primary"
                    data-t="nav_mentor">Mentor</a
                >
            </div>

            <!-- Call to Action -->
            <div class="flex items-center space-x-3 md:space-x-6">
                <!-- Language Toggle Desktop -->
                <div class="hidden lg:flex" id="lang-toggle-container">
                    <button
                        id="lang-toggle-desktop"
                        class="bg-accent px-4 py-1.5 rounded-full text-xs font-bold transition-all duration-300 text-secondary border border-accent hover:bg-accent"
                        >EN</button
                    >
                </div>
                <a
                    href="https://wa.me/6287736696629?text=Halo%20saya%20ingin%20bertanya%20terkait%20Enggroho"
                    class="btn-primary text-white px-5 md:px-8 py-3 md:py-3.5 rounded-2xl font-bold text-xs md:text-sm shadow-xl whitespace-nowrap"
                    data-t="nav_cta"
                >
                    Konsultasi Gratis
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section
        id="hero"
        class="relative flex items-center pt-48 pb-24 px-6 overflow-hidden"
    >
        <div class="blob-bg -top-24 -right-24"></div>
        <div class="blob-bg -bottom-48 -left-24 opacity-60"></div>

        <div
            class="max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-20 items-center"
        >
            <div class="relative z-10" data-aos="fade-right">
                <div
                    class="inline-flex items-center space-x-3 mb-8 px-5 py-2.5 bg-cream rounded-2xl border border-accent"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-primary"
                        ></span>
                    </span>
                    <span
                        class="text-secondary text-[11px] font-bold uppercase tracking-widest"
                        data-t="hero_badge">Global Career Accelerator</span
                    >
                </div>

                <h1
                    class="text-4xl sm:text-5xl md:text-7xl font-extrabold leading-[1.1] mb-8 text-secondary tracking-tight"
                    data-t="hero_title"
                >
                    Convert Opportunities with <span class="gradient-text italic"
                        >Fluent</span
                    > English
                </h1>

                <p
                    class="text-lg md:text-xl text-secondary mb-12 leading-relaxed max-w-xl font-light"
                    data-t="hero_desc"
                >
                    Transformasikan cara Anda berkomunikasi. Kami tidak hanya
                    mengajar bahasa, kami membantu Anda membangun <span
                        class="text-secondary font-semibold"
                        >karakter profesional</span
                    > di kancah internasional.
                </p>

                <div class="flex flex-col sm:flex-row items-center gap-6 mb-10">
                    <a
                        href="https://wa.me/6287736696629?text=Halo%20saya%20ingin%20bertanya%20terkait%20Enggroho"
                        class="btn-primary text-white px-10 py-4.5 rounded-3xl font-bold text-center text-lg w-full sm:w-auto shadow-2xl shadow-primary/20"
                        data-t="hero_cta"
                    >
                        Mulai Perjalanan Anda
                    </a>
                    <a
                        href="https://calendly.com/enggroho/linkdln-session-career-talk"
                        class="glass-card px-10 py-4.5 rounded-3xl font-bold text-center text-lg w-full sm:w-auto text-secondary hover:bg-white hover:shadow-lg transition-all border-2 border-primary/20"
                        data-t="hero_calendly"
                    >
                        Jadwalkan Pertemuan
                    </a>
                </div>

                <div class="flex items-center space-x-4">
                    <div class="flex -space-x-3">
                        <img
                            src="https://i.pravatar.cc/150?u=a1"
                            class="w-11 h-11 rounded-full border-2 border-accent shadow-md"
                            alt="User"
                        />
                        <img
                            src="https://i.pravatar.cc/150?u=a2"
                            class="w-11 h-11 rounded-full border-2 border-accent shadow-md"
                            alt="User"
                        />
                        <img
                            src="https://i.pravatar.cc/150?u=a3"
                            class="w-11 h-11 rounded-full border-2 border-accent shadow-md"
                            alt="User"
                        />
                        <div
                            class="w-11 h-11 rounded-full border-2 border-accent bg-primary text-white flex items-center justify-center text-[10px] font-black shadow-md"
                        >
                            50+
                        </div>
                    </div>
                    <p
                        class="text-xs font-medium text-secondary leading-tight"
                        data-t="hero_trust"
                    >
                        Dipercaya oleh para<br /><span
                            class="text-secondary font-bold"
                            >Professionals</span
                        >
                    </p>
                </div>
            </div>

            <div
                class="relative"
                data-aos="zoom-out-up"
                data-aos-duration="1200"
            >
                <div
                    class="absolute -top-10 -right-5 w-32 h-32 bg-yellow-400/20 rounded-full blur-3xl"
                >
                </div>

                <div
                    class="absolute -left-12 top-20 glass-card p-6 flex items-center space-x-4 floating z-30 border-accent/50"
                >
                    <div
                        class="w-12 h-12 bg-primary text-white rounded-2xl flex items-center justify-center text-xl shadow-lg"
                    >
                        <i class="fas fa-rocket"></i>
                    </div>
                    <div>
                        <p
                            class="text-[10px] uppercase font-bold text-secondary"
                            data-t="hero_card_label"
                        >
                            Career Growth
                        </p>
                        <p
                            class="text-sm font-extrabold text-secondary"
                            data-t="hero_card_value"
                        >
                            Accelerated
                        </p>
                    </div>
                </div>

                <div class="creative-frame relative group">
                    <img
                        src="/hero.png"
                        alt="Professional Leadership"
                        class="w-full h-[600px] object-cover transition-transform duration-1000 group-hover:scale-105"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-rose-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Methodology Section -->
    <section id="approach" class="pt-32 pb-16 px-6 bg-cream overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div
                class="flex flex-col items-center text-center mb-16"
                data-aos="fade-up"
            >
                <span
                    class="text-secondary font-bold text-xs uppercase tracking-[0.3em] mb-6 px-4 py-1.5 rounded-full bg-accent"
                    data-t="section_approach_badge"
                    >OUR CREATIVE APPROACH</span
                >
                <h2
                    class="text-4xl md:text-5xl font-extrabold text-secondary tracking-tight"
                    data-t="section_approach_title"
                >
                    Metode Belajar Tanpa Batas
                </h2>
            </div>

            <div class="grid md:grid-cols-3 gap-10">
                <div
                    class="glass-card p-12 hover:border-accent"
                    data-aos="fade-up"
                    data-aos-delay="100"
                >
                    <div
                        class="w-14 h-14 bg-accent text-secondary rounded-2xl flex items-center justify-center mb-8 text-2xl"
                    >
                        <i class="fas fa-fingerprint"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold mb-5 tracking-tight"
                        data-t="approach_card1_title"
                    >
                        Ultra Personalized
                    </h3>
                    <p
                        class="text-secondary leading-relaxed font-light"
                        data-t="approach_card1_desc"
                    >
                        Kurikulum yang berputar di sekitar dunia kerja Anda.
                        Anda belajar apa yang Anda butuhkan besok di kantor.
                    </p>
                </div>

                <div
                    class="glass-card p-12 bg-secondary border-none group hover:scale-[1.02]"
                    data-aos="fade-up"
                    data-aos-delay="200"
                >
                    <div
                        class="w-14 h-14 bg-primary text-white rounded-2xl flex items-center justify-center mb-8 text-2xl group-hover:rotate-12 transition-transform"
                    >
                        <i class="fas fa-brain"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold mb-5 text-white tracking-tight"
                        data-t="approach_card2_title"
                    >
                        Cognitive Context
                    </h3>
                    <p
                        class="text-white/80 leading-relaxed font-light"
                        data-t="approach_card2_desc"
                    >
                        Kami melatih otak Anda untuk berpikir langsung dalam
                        bahasa Inggris, bukan sekadar menerjemahkan kata.
                    </p>
                </div>

                <div
                    class="glass-card p-12 hover:border-accent"
                    data-aos="fade-up"
                    data-aos-delay="300"
                >
                    <div
                        class="w-14 h-14 bg-accent text-secondary rounded-2xl flex items-center justify-center mb-8 text-2xl"
                    >
                        <i class="fas fa-infinity"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold mb-5 tracking-tight"
                        data-t="approach_card3_title"
                    >
                        Unlimited Support
                    </h3>
                    <p
                        class="text-secondary leading-relaxed font-light"
                        data-t="approach_card3_desc"
                    >
                        Akses tanya jawab di luar sesi kelas. Kami adalah
                        partner komunikasi Anda setiap saat.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Section -->
    <section id="why" class="py-24 px-6 bg-white overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-20 items-center mb-16">
                <div data-aos="fade-right">
                    <h2 class="text-4xl md:text-5xl font-extrabold text-secondary mb-8 tracking-tight" data-t="section_why_title">KENAPA ENGGROHO?</h2>
                    <p class="text-xl font-bold text-primary mb-6" data-t="section_why_subtitle">Bukan Sekadar Kursus Bahasa Inggris Biasa</p>
                    <div class="space-y-6 text-secondary font-light leading-relaxed">
                        <p data-t="why_main_desc">Enggroho adalah kursus bahasa Inggris privat utama...</p>
                        <p data-t="why_extra_desc1">Tidak seperti kursus bahasa tradisional...</p>
                        <p data-t="why_extra_desc2">Dengan sesi online satu lawan satu...</p>
                    </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-aos="fade-left">
                    {[1, 2, 3, 4, 5, 6, 7].map((num) => (
                        <div class="glass-card p-6 border border-secondary/5 hover:border-primary/20 transition-all">
                            <div class="w-10 h-10 bg-accent rounded-xl flex items-center justify-center text-primary mb-4">
                                <i class={`fas ${num === 1 ? 'fa-video' : num === 2 ? 'fa-calendar-alt' : num === 3 ? 'fa-headset' : num === 4 ? 'fa-certificate' : num === 5 ? 'fa-briefcase' : num === 6 ? 'fa-user-tie' : 'fa-chart-line'}`}></i>
                            </div>
                            <h4 class="font-bold text-secondary mb-2" data-t={`why_feat${num}_title`}>Feature {num}</h4>
                            <p class="text-xs text-secondary/70 font-light" data-t={`why_feat${num}_desc`}>Description {num}</p>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- Stats / Impact Section -->
    <section class="pt-8 pb-24 px-6 bg-cream overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div
                class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12"
                data-aos="fade-up"
            >
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-primary mb-3 font-heading"
                        data-t="stats_alumni_val"
                    >
                        50+
                    </p>
                    <p
                        class="text-sm text-secondary font-medium uppercase tracking-wider"
                        data-t="stats_alumni"
                    >
                        Alumni Aktif
                    </p>
                </div>
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-secondary mb-3 font-heading"
                        data-t="stats_experience_val"
                    >
                        5+
                    </p>
                    <p
                        class="text-sm text-secondary font-medium uppercase tracking-wider"
                        data-t="stats_experience"
                    >
                        Tahun Pengalaman
                    </p>
                </div>
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-primary mb-3 font-heading"
                        data-t="stats_satisfaction_val"
                    >
                        98%
                    </p>
                    <p
                        class="text-sm text-secondary font-medium uppercase tracking-wider"
                        data-t="stats_satisfaction"
                    >
                        Tingkat Kepuasan
                    </p>
                </div>
                <div class="text-center p-8 glass-card">
                    <p
                        class="text-4xl md:text-5xl font-extrabold text-secondary mb-3 font-heading"
                        data-t="stats_industries_val"
                    >
                        15+
                    </p>
                    <p
                        class="text-sm text-secondary font-medium uppercase tracking-wider"
                        data-t="stats_industries"
                    >
                        Industri Dilayani
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="py-24 px-6 bg-cream overflow-hidden" id="metode">
        <div class="max-w-5xl mx-auto">
                <div
                    class="flex flex-col items-center text-center mb-16"
                    data-aos="fade-up"
                >
                    <span
                        class="text-primary font-bold text-xs uppercase tracking-[0.3em] mb-6 px-4 py-1.5 rounded-full bg-accent"
                        data-t="section_how_badge">HOW IT WORKS</span
                    >
                    <h2
                        class="text-4xl md:text-5xl font-extrabold text-secondary tracking-tight"
                        data-t="section_how_title"
                    >
                        Alur Belajar di Enggroho
                    </h2>
                    <p
                        class="text-secondary mt-6 text-lg max-w-2xl font-light leading-relaxed"
                        data-t="section_how_desc"
                    >
                        Dari proficiency sekarang hingga mahir, kami mendampingi
                        setiap langkah perjalanan Anda menuju komunikasi
                        profesional.
                    </p>
                </div>

            <div class="relative">
                <!-- Vertical Timeline Line -->
                <div
                    class="absolute left-8 md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-[3px] bg-accent z-0"
                >
                </div>
                <div
                    class="absolute left-8 md:left-1/2 md:-translate-x-1/2 top-0 w-[3px] bg-gradient-to-b from-primary to-primary/30 z-[1] timeline-progress"
                    style="height: 0%"
                >
                </div>

                <!-- Step 1 -->
                <div
                    class="step-item relative flex items-start mb-20 md:mb-28"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-cream border-[3px] border-accent flex items-center justify-center text-2xl font-extrabold text-secondary font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">1</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-0 md:w-[42%] md:pr-16">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-primary mb-2 block"
                            data-t="step1_badge">Langkah Pertama</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-secondary"
                            data-t="step1_title"
                        >
                            Konsultasi Gratis
                        </h3>
                        <p
                            class="text-secondary font-light leading-relaxed"
                            data-t="step1_desc"
                        >
                            Kami mendengarkan kebutuhan, tantangan, dan tujuan
                            karir Anda secara menyeluruh. Sesi ini gratis tanpa
                            komitmen apapun.
                        </p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div
                    class="step-item relative flex items-start justify-end mb-20 md:mb-28"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-cream border-[3px] border-accent flex items-center justify-center text-2xl font-extrabold text-secondary font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">2</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-auto md:w-[42%] md:pl-16">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-primary mb-2 block text-left"
                            data-t="step2_badge">Langkah Kedua</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-secondary text-left"
                            data-t="step2_title"
                        >
                            Kurikulum Personal
                        </h3>
                        <p
                            class="text-secondary font-light leading-relaxed text-left"
                            data-t="step2_desc"
                        >
                            Materi disusun khusus berdasarkan industri dan
                            kebutuhan profesional Anda. Tidak ada kurikulum
                            template, semuanya tailor-made yang bertumpu pada
                            proficiency sekarang.
                        </p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div
                    class="step-item relative flex items-start mb-20 md:mb-28"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-cream border-[3px] border-accent flex items-center justify-center text-2xl font-extrabold text-secondary font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">3</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-0 md:w-[42%] md:pr-16">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-rose-400 mb-2 block"
                            data-t="step3_badge">Langkah Ketiga</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-secondary"
                            data-t="step3_title"
                        >
                            Sesi Intensif 1-on-1
                        </h3>
                        <p
                            class="text-secondary font-light leading-relaxed"
                            data-t="step3_desc"
                        >
                            Belajar langsung dengan mentor melalui sesi privat
                            yang fokus dan interaktif. Real practice, real
                            scenario, real progress.
                        </p>
                    </div>
                </div>

                <!-- Step 4 -->
                <div
                    class="step-item relative flex items-start justify-end"
                    data-aos="fade-up"
                >
                    <div
                        class="absolute left-8 md:left-1/2 -translate-x-1/2 z-10"
                    >
                        <div
                            class="step-circle w-16 h-16 rounded-full bg-cream border-[3px] border-accent flex items-center justify-center text-2xl font-extrabold text-secondary font-heading transition-all duration-700 shadow-lg"
                        >
                            <span class="step-number">4</span>
                            <i
                                class="fas fa-check step-check hidden text-white text-xl"
                            ></i>
                        </div>
                    </div>
                    <div class="ml-28 md:ml-0 md:w-[42%] md:pl-16 md:text-left">
                        <span
                            class="text-[10px] uppercase font-bold tracking-widest text-rose-400 mb-2 block"
                            data-t="step4_badge">Langkah Terakhir</span
                        >
                        <h3
                            class="text-2xl font-bold mb-4 tracking-tight text-secondary"
                            data-t="step4_title"
                        >
                            Evaluasi & Follow Up
                        </h3>
                        <p
                            class="text-secondary font-light leading-relaxed"
                            data-t="step4_desc"

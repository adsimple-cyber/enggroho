---
import "../styles/global.css";
import { translations } from "../utils/translations";

interface Props {
	title?: string;
}

const { title = "Enggroho - Creative English for Professionals" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- Security Headers -->
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<meta http-equiv="X-Frame-Options" content="DENY" />
		<meta
			http-equiv="Content-Security-Policy"
			content="default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https://i.pravatar.cc https://images.unsplash.com https://api.dicebear.com https://ui-avatars.com;"
		/>

		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/favicon.png" />

		<!-- SEO & Social Meta Tags -->
		<meta name="description" content="Enggroho - Creative English for Professionals. Elevate your global career with professional English mastery." />
		<meta property="og:title" content="Enggroho - Creative English for Professionals" />
		<meta property="og:description" content="Transformasi cara Anda berkomunikasi. Kami tidak sekadar mengajarkan bahasa, kami membantu Anda membangun karakter profesional di kancah internasional." />
		<meta property="og:image" content="/og-image.png" />
		<meta property="og:url" content="https://enggroho.com" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="/og-image.png" />

		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
			rel="stylesheet"
			integrity="sha512-9usAa10IRO0HhonpyAIVpjrylPvoDwiPUiKdWk5t3PyolY1cOd4DSE0Ga+ri4AuTroPR5aQvXU9xC6qOPnzFeg=="
			crossorigin="anonymous"
			referrerpolicy="no-referrer"
		/>
		<link
			rel="stylesheet"
			href="https://unpkg.com/aos@next/dist/aos.css"
			integrity="sha384-R//NStDhsEea1wA9I0rGj8g6k98E2k9WFXi8q5aW6R+dF30wRIfOOMF2S6V/kK9I"
			crossorigin="anonymous"
		/>
	</head>
	<body>
		<slot />

		<script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				if (typeof AOS !== "undefined") {
					AOS.init({ duration: 1000, once: true });
				}

				window.onscroll = function () {
					let winScroll =
						document.body.scrollTop ||
						document.documentElement.scrollTop;
					let height =
						document.documentElement.scrollHeight -
						document.documentElement.clientHeight;
					let scrolled = (winScroll / height) * 100;
					const progressEl =
						document.getElementById("scroll-progress");
					if (progressEl) {
						progressEl.style.width = scrolled + "%";
					}
				};

				// Step Timeline Animation
				const stepItems = document.querySelectorAll(".step-item");
				const timelineProgress =
					document.querySelector(".timeline-progress");

				if (stepItems.length > 0 && timelineProgress) {
					const observerOptions = {
						root: null,
						threshold: 0.3, // More lenient threshold
						rootMargin: "0px 0px -10% 0px",
					};

					const observer = new IntersectionObserver((entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								const item = entry.target;
								let found = false;
								let activeIdx = -1;

								stepItems.forEach((step, idx) => {
									if (step === item) {
										found = true;
										step.classList.add("active");
										step.classList.remove("completed");
										activeIdx = idx;
									} else if (!found) {
										step.classList.add("completed");
										step.classList.remove("active");
									} else {
										step.classList.remove(
											"active",
											"completed",
										);
									}
								});

								// Animate timeline progress
								const pct =
									(activeIdx / (stepItems.length - 1)) * 100;
								timelineProgress.style.height = pct + "%";
								timelineProgress.style.transition =
									"height 0.8s cubic-bezier(0.4, 0, 0.2, 1)";
							}
						});
					}, observerOptions);

					stepItems.forEach((item) => observer.observe(item));

					// Final check for the very last item when scrolling past it
					window.addEventListener("scroll", () => {
						const lastStep = stepItems[stepItems.length - 1];
						if (
							lastStep.getBoundingClientRect().bottom <
							window.innerHeight * 0.5
						) {
							lastStep.classList.add("completed");
							lastStep.classList.remove("active");
							timelineProgress.style.height = "100%";
						}
					});
				}
				// Social Proof Notification

				const notification =
					document.getElementById("social-proof-toast");
				const proofTarget = document.getElementById("proof-text");

				if (notification && proofTarget) {
					function showRandomProof() {
						const currentLang =
							localStorage.getItem("language") || "id";
						const proofs = translations[currentLang].social_proofs;
						const randomIdx = Math.floor(
							Math.random() * proofs.length,
						);
						proofTarget.innerText = proofs[randomIdx];
						notification.classList.remove(
							"translate-x-[-150%]",
							"opacity-0",
						);
						notification.classList.add(
							"translate-x-0",
							"opacity-100",
						);

						setTimeout(() => {
							notification.classList.add(
								"translate-x-[-150%]",
								"opacity-0",
							);
							notification.classList.remove(
								"translate-x-0",
								"opacity-100",
							);
						}, 5000);
					}

					// Start showing after 3 seconds
					setTimeout(() => {
						showRandomProof();
						setInterval(showRandomProof, 15000); // Repeat every 15 seconds
					}, 3000);
				}


			});
		</script>

		<!-- Social Proof Toast -->
		<div
			id="social-proof-toast"
			class="fixed bottom-32 left-6 right-6 md:left-8 md:right-auto md:w-80 bg-cream/95 backdrop-blur-xl border border-secondary/10 p-4 rounded-2xl shadow-xl z-[98] transition-all duration-700 translate-x-[-150%] opacity-0 flex items-center gap-4"
		>
			<div
				class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white shrink-0 shadow-lg shadow-primary/20"
			>
				<i class="fas fa-bell animate-pulse"></i>
			</div>
			<div>
				<p
					id="proof-text"
					class="text-xs font-bold text-secondary leading-tight"
				>
				</p>
				<p
					class="text-[10px] text-secondary/60 mt-1 font-medium italic"
					data-t="just_now"
				>
					Baru saja dilakukan
				</p>
			</div>
			<button
				onclick="this.parentElement.style.display='none'"
				class="text-slate-200 hover:text-slate-400 ml-auto self-start"
			>
				<i class="fas fa-times text-xs"></i>
			</button>
		</div>

		<!-- Mobile Bottom Navbar -->
		<nav
			class="md:hidden fixed bottom-6 left-6 right-6 bg-secondary/95 backdrop-blur-xl border border-white/20 rounded-[2.5rem] p-2 px-6 z-[99] shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex items-center justify-around h-16"
		>
			<div id="mobile-indicator" class="mobile-indicator"></div>
			
			<a
				href="#hero"
				class="mobile-nav-link flex flex-col items-center gap-1 p-2 transition-all relative z-10"
				data-section="hero"
			>
				<i class="fas fa-home text-white/40 text-sm"></i>
				<span class="text-[9px] text-white/40 font-bold uppercase tracking-tight">Home</span>
			</a>
			<a
				href="#metode"
				class="mobile-nav-link flex flex-col items-center gap-1 p-2 transition-all relative z-10"
				data-section="metode"
			>
				<i class="fas fa-bullseye text-white/40 text-sm"></i>
				<span class="text-[9px] text-white/40 font-bold uppercase tracking-tight">Alur</span>
			</a>
			<a
				href="#fitur"
				class="mobile-nav-link flex flex-col items-center gap-1 p-2 transition-all relative z-10"
				data-section="fitur"
			>
				<i class="fas fa-rocket text-white/40 text-sm"></i>
				<span class="text-[9px] text-white/40 font-bold uppercase tracking-tight">Fitur</span>
			</a>
			<a
				href="#testimonials"
				class="mobile-nav-link flex flex-col items-center gap-1 p-2 transition-all relative z-10"
				data-section="testimonials"
			>
				<i class="fas fa-comment-dots text-white/40 text-sm"></i>
				<span class="text-[9px] text-white/40 font-bold uppercase tracking-tight">Testi</span>
			</a>
		</nav>

		<style is:global>
			.mobile-indicator {
				position: absolute;
				width: 44px;
				height: 44px;
				background: #FF6D1F;
				border-radius: 50%;
				z-index: 0;
				transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
				box-shadow: 0 8px 20px rgba(255, 109, 31, 0.4);
				top: 50%;
				transform: translateY(-50%);
			}

			.mobile-nav-link.active i,
			.mobile-nav-link.active span {
				color: white !important;
				opacity: 1 !important;
			}

			.mobile-nav-link.active i {
				transform: scale(1.1);
			}

			/* Script to handle mobile nav */
			@media (max-width: 768px) {
				.mobile-nav-link {
					width: 50px;
					justify-content: center;
				}
			}
		</style>

		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				const mobileLinks = document.querySelectorAll('.mobile-nav-link');
				const indicator = document.getElementById('mobile-indicator');
				// Sections in physical order on the page
				const sections = ['hero', 'testimonials', 'metode', 'fitur'];

				function updateMobileNav() {
					let currentSection = 'hero';
					const scrollPos = window.scrollY + 300; // Trigger slightly earlier for better feel

					sections.forEach(id => {
						const el = document.getElementById(id);
						if (el && scrollPos >= el.offsetTop) {
							currentSection = id;
						}
					});

					mobileLinks.forEach(link => {
						const sectionId = link.getAttribute('data-section');
						if (sectionId === currentSection) {
							link.classList.add('active');
							// Move indicator
							if (indicator) {
								indicator.style.left = (link.offsetLeft + (link.offsetWidth / 2) - 22) + 'px';
								indicator.style.opacity = '1';
							}
						} else {
							link.classList.remove('active');
						}
					});
				}

				window.addEventListener('scroll', updateMobileNav, { passive: true });
				window.addEventListener('resize', updateMobileNav);
				
				// Run after small delay to ensure layout is ready
				setTimeout(updateMobileNav, 200);
			});
		</script>
	</body>
</html>

---
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Enggroho - Creative English for Professionals" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- Security Headers -->
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<meta http-equiv="X-Frame-Options" content="DENY" />
		<meta
			http-equiv="Content-Security-Policy"
			content="default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https://i.pravatar.cc https://images.unsplash.com;"
		/>

		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
			rel="stylesheet"
			integrity="sha512-9usAa10IRO0HhonpyAIVpjrylPvoDwiPUiKdWk5t3PyolY1cOd4DSE0Ga+ri4AuTroPR5aQvXU9xC6qOPnzFeg=="
			crossorigin="anonymous"
			referrerpolicy="no-referrer"
		/>
		<link
			rel="stylesheet"
			href="https://unpkg.com/aos@next/dist/aos.css"
			integrity="sha384-R//NStDhsEea1wA9I0rGj8g6k98E2k9WFXi8q5aW6R+dF30wRIfOOMF2S6V/kK9I"
			crossorigin="anonymous"
		/>
	</head>
	<body>
		<slot />

		<script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				if (typeof AOS !== "undefined") {
					AOS.init({ duration: 1000, once: true });
				}

				window.onscroll = function () {
					let winScroll =
						document.body.scrollTop ||
						document.documentElement.scrollTop;
					let height =
						document.documentElement.scrollHeight -
						document.documentElement.clientHeight;
					let scrolled = (winScroll / height) * 100;
					const progressEl =
						document.getElementById("scroll-progress");
					if (progressEl) {
						progressEl.style.width = scrolled + "%";
					}
				};

				// Step Timeline Animation
				const stepItems = document.querySelectorAll(".step-item");
				const timelineProgress =
					document.querySelector(".timeline-progress");

				if (stepItems.length > 0 && timelineProgress) {
					const observerOptions = {
						root: null,
						threshold: 0.3, // More lenient threshold
						rootMargin: "0px 0px -10% 0px",
					};

					const observer = new IntersectionObserver((entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								const item = entry.target;
								let found = false;
								let activeIdx = -1;

								stepItems.forEach((step, idx) => {
									if (step === item) {
										found = true;
										step.classList.add("active");
										step.classList.remove("completed");
										activeIdx = idx;
									} else if (!found) {
										step.classList.add("completed");
										step.classList.remove("active");
									} else {
										step.classList.remove(
											"active",
											"completed",
										);
									}
								});

								// Animate timeline progress
								const pct =
									(activeIdx / (stepItems.length - 1)) * 100;
								timelineProgress.style.height = pct + "%";
								timelineProgress.style.transition =
									"height 0.8s cubic-bezier(0.4, 0, 0.2, 1)";
							}
						});
					}, observerOptions);

					stepItems.forEach((item) => observer.observe(item));

					// Final check for the very last item when scrolling past it
					window.addEventListener("scroll", () => {
						const lastStep = stepItems[stepItems.length - 1];
						if (
							lastStep.getBoundingClientRect().bottom <
							window.innerHeight * 0.5
						) {
							lastStep.classList.add("completed");
							lastStep.classList.remove("active");
							timelineProgress.style.height = "100%";
						}
					});
				}
				// Social Proof Notification
				const socialProofs = [
					"Budi dari Jakarta baru saja booking konsultasi",
					"Santi dari Surabaya baru saja join kelas privat",
					"Andi mendownload modul kurikulum personal",
					"Rina dari Bandung baru saja menyelesaikan tes level",
					"Dimas dari Medan sedang konsultasi dengan Agung",
					"Lina baru saja mendapatkan sertifikat English Mastery",
					"Fajar dari Semarang mendaftar kelas Speaking Intensif",
					"Maya dari Denpasar baru saja booking slot jadwal",
					"Hendra dari Jogja join sebagai alumni aktif",
					"Dewi sedang diskusi materi Business Writing",
					"Adi dari Makassar baru saja tes level gratis",
					"Novi baru saja join di grup belajar privat",
					"Yanto dari Solo baru saja konsultasi via WhatsApp",
					"Eka dari Balikpapan mendownload progress report",
					"Rully baru saja booking sesi 1-on-1 malam ini",
					"Ika dari Malang mendaftar paket 3 bulan",
					"Dedi dari Palembang baru saja join kelas pagi",
					"Putri dari Manado sedang tes penempatan level",
					"Galih baru saja booking konsultasi pertama",
					"Wulan dari Lampung join kelas profesional",
				];

				const notification =
					document.getElementById("social-proof-toast");
				const proofTarget = document.getElementById("proof-text");

				if (notification && proofTarget) {
					function showRandomProof() {
						const randomIdx = Math.floor(
							Math.random() * socialProofs.length,
						);
						proofTarget.innerText = socialProofs[randomIdx];
						notification.classList.remove(
							"translate-x-[-150%]",
							"opacity-0",
						);
						notification.classList.add(
							"translate-x-0",
							"opacity-100",
						);

						setTimeout(() => {
							notification.classList.add(
								"translate-x-[-150%]",
								"opacity-0",
							);
							notification.classList.remove(
								"translate-x-0",
								"opacity-100",
							);
						}, 5000);
					}

					// Start showing after 3 seconds
					setTimeout(() => {
						showRandomProof();
						setInterval(showRandomProof, 15000); // Repeat every 15 seconds
					}, 3000);
				}

				// Navbar Active Highlight Logic
				const navLinks = document.querySelectorAll("nav.md\\:hidden a");
				const sections = [
					"#hero",
					"#metode",
					"#fitur",
					"#testimoni",
				].map((id) => document.querySelector(id));

				if (navLinks.length > 0 && sections.every((s) => s)) {
					const navObserver = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									const id = "#" + entry.target.id;
									navLinks.forEach((link) => {
										const icon = link.querySelector("i");
										const label =
											link.querySelector("span");
										const isFitur =
											link.getAttribute("href") ===
											"#fitur";
										if (link.getAttribute("href") === id) {
											if (!isFitur) {
												icon.classList.add(
													"text-rose-500",
												);
												icon.classList.remove(
													"text-white/40",
												);
											}
											label.classList.add("text-white");
											label.classList.remove(
												"text-white/40",
											);
											link.classList.add(
												"scale-110",
												"opacity-100",
											);
											link.classList.remove("opacity-50");
										} else {
											if (!isFitur) {
												icon.classList.add(
													"text-white/40",
												);
												icon.classList.remove(
													"text-rose-500",
												);
											}
											label.classList.add(
												"text-white/40",
											);
											label.classList.remove(
												"text-white",
											);
											link.classList.remove(
												"scale-110",
												"opacity-100",
											);
											link.classList.add("opacity-50");
										}
									});
								}
							});
						},
						{ threshold: 0.5 },
					);

					sections.forEach((s) => navObserver.observe(s));
				}
			});
		</script>

		<!-- Social Proof Toast -->
		<div
			id="social-proof-toast"
			class="fixed bottom-32 left-6 right-6 md:left-8 md:right-auto md:w-80 bg-white/90 backdrop-blur-xl border border-slate-100 p-4 rounded-2xl shadow-xl z-[98] transition-all duration-700 translate-x-[-150%] opacity-0 flex items-center gap-4"
		>
			<div
				class="w-10 h-10 bg-rose-500 rounded-full flex items-center justify-center text-white shrink-0 shadow-lg shadow-rose-200"
			>
				<i class="fas fa-bell animate-pulse"></i>
			</div>
			<div>
				<p
					id="proof-text"
					class="text-xs font-bold text-slate-800 leading-tight"
				>
				</p>
				<p class="text-[10px] text-slate-400 mt-1 font-medium italic">
					Baru saja dilakukan
				</p>
			</div>
			<button
				onclick="this.parentElement.style.display='none'"
				class="text-slate-200 hover:text-slate-400 ml-auto self-start"
			>
				<i class="fas fa-times text-xs"></i>
			</button>
		</div>

		<!-- Mobile Bottom Navbar -->
		<nav
			class="md:hidden fixed bottom-6 left-6 right-6 bg-slate-900/95 backdrop-blur-xl border border-white/20 rounded-[2.5rem] p-2 px-6 z-[99] shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex items-center justify-around"
		>
			<a
				href="#hero"
				class="flex flex-col items-center gap-1.5 p-2 transition-all active:scale-90"
			>
				<i class="fas fa-home text-white/40 text-base"></i>
				<span
					class="text-[9px] text-white/40 font-bold uppercase tracking-tight leading-none"
					>Home</span
				>
			</a>
			<a
				href="#metode"
				class="flex flex-col items-center gap-1.5 p-2 transition-all active:scale-90"
			>
				<i class="fas fa-bullseye text-white/40 text-base"></i>
				<span
					class="text-[9px] text-white/40 font-bold uppercase tracking-tight leading-none"
					>Alur</span
				>
			</a>
			<a
				href="#fitur"
				class="flex flex-col items-center gap-1.5 p-2 transition-all group active:scale-90"
			>
				<div
					class="w-12 h-12 bg-rose-500 rounded-full flex items-center justify-center -mt-10 mb-0 shadow-[0_10px_25px_-5px_rgba(255,51,102,0.5)] border-4 border-slate-900 group-active:scale-95 transition-transform"
				>
					<i class="fas fa-rocket text-white text-lg"></i>
				</div>
				<span
					class="text-[9px] text-white/40 font-bold uppercase tracking-tight leading-none"
					>Fitur</span
				>
			</a>
			<a
				href="#testimoni"
				class="flex flex-col items-center gap-1.5 p-2 transition-all active:scale-90"
			>
				<i class="fas fa-comment-dots text-white/40 text-base"></i>
				<span
					class="text-[9px] text-white/40 font-bold uppercase tracking-tight leading-none"
					>Testi</span
				>
			</a>
		</nav>
	</body>
</html>
